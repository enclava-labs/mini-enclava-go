{{define "layout-nav"}}
  <nav class="fixed top-0 left-0 right-0 z-50 bg-card/80 backdrop-blur-lg border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex justify-between h-16">
        <div class="flex items-center gap-6">
          <a href="/dashboard" class="text-xl font-display font-bold gradient-text">Enclava</a>
          <div class="hidden sm:flex items-center gap-1">
            <a href="/dashboard" class="tab-button{{if eq .ActivePage "dashboard"}} active{{end}} px-3 py-2 text-sm font-medium rounded-md">Dashboard</a>
            <a href="/dashboard/extract" class="tab-button{{if eq .ActivePage "extract"}} active{{end}} px-3 py-2 text-sm font-medium rounded-md">Extract</a>
            <a href="/dashboard/keys" class="tab-button{{if eq .ActivePage "keys"}} active{{end}} px-3 py-2 text-sm font-medium rounded-md">API Keys</a>
            <a href="/dashboard/budgets" class="tab-button{{if eq .ActivePage "budgets"}} active{{end}} px-3 py-2 text-sm font-medium rounded-md">Budgets</a>
            <a href="/dashboard/analytics" class="tab-button{{if eq .ActivePage "analytics"}} active{{end}} px-3 py-2 text-sm font-medium rounded-md">Analytics</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button onclick="toggleTheme()" class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-muted" title="Toggle theme">
            <svg class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <svg class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </button>
          {{if eq .AuthMode "password"}}
          <span class="text-sm text-muted-foreground">{{.AdminEmail}}</span>
          <form method="post" action="/dashboard/logout">
            <button type="submit" class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-muted" title="Sign out">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            </button>
          </form>
          {{else}}
          <span class="text-sm text-muted-foreground">API Key Mode</span>
          {{end}}
        </div>
      </div>
    </div>
  </nav>
{{end}}
