<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Login - Enclava</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard/static/tailwind.css">
  <script>
    (function() {
      var stored = localStorage.getItem('enclava-theme');
      if (stored === 'light') document.documentElement.classList.remove('dark');
    })();
  </script>
</head>
<body class="min-h-screen bg-background text-foreground">
  <main class="min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-display font-bold gradient-text">Enclava</h1>
        <p class="text-muted-foreground mt-2">Sign in to the dashboard</p>
      </div>

      <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
        {{if .Error}}
        <div class="rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-200 p-4 mb-4" role="alert">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm">{{.Error}}</p>
          </div>
        </div>
        {{end}}

        <form method="post" action="/dashboard/login" class="space-y-4" autocomplete="off">
          <div class="space-y-2">
            <label for="email" class="text-sm font-medium leading-none">Email</label>
            <input
              required
              type="email"
              id="email"
              name="email"
              value="{{.Email}}"
              class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
              placeholder="admin@example.com"
            >
          </div>
          <div class="space-y-2">
            <label for="password" class="text-sm font-medium leading-none">Password</label>
            <input
              required
              type="password"
              id="password"
              name="password"
              class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
              placeholder="••••••••"
            >
          </div>
          <div class="pt-2">
            <button type="submit" class="inline-flex w-full items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4">
              Sign in
            </button>
          </div>
        </form>
      </div>

      <p class="text-center text-sm text-muted-foreground mt-6">
        Secure, confidential AI processing powered by
        <a href="https://privatemode.ai" target="_blank" rel="noopener" class="text-primary hover:underline">
          privatemode.ai
        </a>
      </p>
    </div>
  </main>
</body>
</html>
