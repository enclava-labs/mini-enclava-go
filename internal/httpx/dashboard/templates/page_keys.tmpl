{{define "page-keys"}}
{{template "layout-head" .}}
{{template "layout-nav" .}}

  <main class="pt-16 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 space-y-6">
      <div id="dashboard-message" class="min-h-[1.5rem] text-sm"></div>

      {{if eq .AuthMode "api_key"}}
      <section id="api-key-login-panel" class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
        <h2 class="text-lg font-display font-semibold">Unlock dashboard</h2>
        <p class="mt-1 text-sm text-muted-foreground">
          Paste an API key with dashboard scopes to authenticate browser actions.
        </p>
        <form id="api-key-form" class="mt-4 flex flex-col gap-3 sm:flex-row" autocomplete="off">
          <input id="api-key-input" type="password" required class="flex h-10 min-w-0 flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" placeholder="enc_...">
          <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4">
            Use this key
          </button>
        </form>
        <p class="mt-2 text-xs text-muted-foreground">The key is stored in this browser only (localStorage).</p>
      </section>
      {{end}}

      <section id="dashboard-shell" class="space-y-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          {{if eq .AuthMode "api_key"}}
          <p class="text-sm text-muted-foreground">
            Active key: <span id="active-api-key" class="font-mono text-primary">Not set</span>
          </p>
          <button id="clear-api-key" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
            Clear key
          </button>
          {{else}}
          <div>
            <h1 class="text-3xl font-display font-bold">API Keys</h1>
            <p class="text-muted-foreground mt-1">Manage API keys for external integrations.</p>
          </div>
          {{end}}
        </div>

        <section class="rounded-lg border bg-card text-card-foreground shadow-sm">
          <div class="flex flex-col space-y-1.5 p-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-2xl font-display font-semibold leading-none tracking-tight">API Keys</h3>
                <p class="text-sm text-muted-foreground mt-1">Manage API keys for external integrations.</p>
              </div>
              <button
                type="button"
                onclick="document.getElementById('create-key-form').classList.toggle('hidden')"
                class="inline-flex items-center gap-2 justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Create API Key
              </button>
            </div>
          </div>
          <div class="p-6 pt-0 space-y-4">
            <div id="create-key-form" class="hidden">
              <form
                class="grid grid-cols-1 gap-3 rounded-md border bg-muted/50 p-4 sm:grid-cols-2"
                hx-post="/dashboard/partials/keys"
                hx-target="#dashboard-keys-list"
                hx-swap="innerHTML"
                hx-on::after-request="document.getElementById('create-key-form').classList.add('hidden'); this.reset()"
              >
                <input type="hidden" name="action" value="create">
                <input type="hidden" name="scopes" value="{{.DefaultScopes}}">
                <div class="space-y-2">
                  <label for="key-name" class="text-sm font-medium leading-none">Name</label>
                  <input
                    required
                    id="key-name"
                    name="name"
                    class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    placeholder="team-admin"
                  >
                </div>
                <div class="space-y-2">
                  <label for="key-description" class="text-sm font-medium leading-none">Description</label>
                  <input
                    id="key-description"
                    name="description"
                    class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                    placeholder="Used by internal tools"
                  >
                </div>
                <div class="sm:col-span-2 flex items-center gap-3 justify-end">
                  <button
                    type="button"
                    onclick="document.getElementById('create-key-form').classList.add('hidden')"
                    class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                  >
                    Cancel
                  </button>
                  <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4">
                    Create key
                  </button>
                </div>
              </form>
            </div>

            <div id="dashboard-keys-list" hx-get="/dashboard/partials/keys" hx-trigger="load" hx-target="this" hx-swap="innerHTML">
              <div class="flex items-center gap-2 text-sm text-muted-foreground py-4">
                <div class="spinner border-current"></div>
                Loading keys...
              </div>
            </div>
          </div>
        </section>
      </section>
    </div>
  </main>

{{template "layout-toast" .}}
{{end}}
