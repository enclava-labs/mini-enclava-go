{{define "partial-stats"}}
<section id="dashboard-stats" class="space-y-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Active API Keys</p>
          <p class="text-2xl font-bold mt-1">{{.ActiveAPIKeys}}</p>
        </div>
        <div class="p-3 rounded-full bg-primary/10 text-primary">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Extract Jobs (24h)</p>
          <p class="text-2xl font-bold mt-1">{{.RecentExtractJobs}}</p>
        </div>
        <div class="p-3 rounded-full bg-primary/10 text-primary">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Total Extract Jobs</p>
          <p class="text-2xl font-bold mt-1">{{.TotalExtractJobs}}</p>
        </div>
        <div class="p-3 rounded-full bg-primary/10 text-primary">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Budget Usage</p>
          <p class="text-2xl font-bold mt-1">{{.BudgetPercent}}%</p>
          <p class="text-sm text-muted-foreground mt-1">{{.BudgetUsed}} / {{.BudgetTotal}}</p>
        </div>
        <div class="p-3 rounded-full bg-primary/10 text-primary">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <h3 class="text-2xl font-display font-semibold leading-none tracking-tight">Extract Documents</h3>
      <p class="text-sm text-muted-foreground mt-1">Process documents with AI-powered extraction.</p>
      <div class="mt-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="p-2 rounded-full bg-primary/10 text-primary">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-medium">Extract Module</p>
            <p class="text-sm text-green-600 dark:text-green-400">Enabled</p>
          </div>
        </div>
        <a href="/dashboard/extract" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
          Open
        </a>
      </div>
    </div>

    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <h3 class="text-2xl font-display font-semibold leading-none tracking-tight">API Endpoint</h3>
      <p class="text-sm text-muted-foreground mt-1">Use the REST API for integrations.</p>
      <div class="mt-4 space-y-3">
        <div class="flex items-center gap-2 p-3 bg-muted rounded-md font-mono text-sm">
          <code id="api-endpoint" class="min-w-0 flex-1 truncate text-muted-foreground"></code>
          <button id="copy-api-endpoint" type="button" class="shrink-0 p-1.5 rounded hover:bg-accent" title="Copy">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
            </svg>
          </button>
        </div>
        <div class="flex items-center gap-2 text-sm">
          <a href="/dashboard/keys" class="text-primary hover:underline">Manage API Keys</a>
          <span class="text-muted-foreground">|</span>
          <a href="/api/v1/models" class="text-primary hover:underline">List Models</a>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <a href="/dashboard/extract" class="p-4 rounded-lg border bg-card hover:bg-accent/50 transition-colors group">
      <svg class="h-8 w-8 text-muted-foreground group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p class="font-medium mt-2">Extract</p>
      <p class="text-sm text-muted-foreground">Document processing</p>
    </a>
    <a href="/dashboard/keys" class="p-4 rounded-lg border bg-card hover:bg-accent/50 transition-colors group">
      <svg class="h-8 w-8 text-muted-foreground group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
      </svg>
      <p class="font-medium mt-2">API Keys</p>
      <p class="text-sm text-muted-foreground">Manage access</p>
    </a>
    <a href="/dashboard/budgets" class="p-4 rounded-lg border bg-card hover:bg-accent/50 transition-colors group">
      <svg class="h-8 w-8 text-muted-foreground group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
      </svg>
      <p class="font-medium mt-2">Budgets</p>
      <p class="text-sm text-muted-foreground">Track spend</p>
    </a>
    <a href="/dashboard/analytics" class="p-4 rounded-lg border bg-card hover:bg-accent/50 transition-colors group">
      <svg class="h-8 w-8 text-muted-foreground group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      <p class="font-medium mt-2">Analytics</p>
      <p class="text-sm text-muted-foreground">View usage</p>
    </a>
  </div>
</section>
{{end}}
