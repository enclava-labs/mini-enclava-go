{{define "page-extract"}}
{{template "layout-head" .}}
{{template "layout-nav" .}}

  <main class="pt-16 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 space-y-6">
      <div id="dashboard-message" class="min-h-[1.5rem] text-sm"></div>

      {{if eq .AuthMode "api_key"}}
      <section id="api-key-login-panel" class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
        <h2 class="text-lg font-display font-semibold">Unlock dashboard</h2>
        <p class="mt-1 text-sm text-muted-foreground">
          Paste an API key with dashboard scopes to authenticate browser actions.
        </p>
        <form id="api-key-form" class="mt-4 flex flex-col gap-3 sm:flex-row" autocomplete="off">
          <input id="api-key-input" type="password" required class="flex h-10 min-w-0 flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" placeholder="enc_...">
          <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4">
            Use this key
          </button>
        </form>
        <p class="mt-2 text-xs text-muted-foreground">The key is stored in this browser only (localStorage).</p>
      </section>
      {{end}}

      <section id="dashboard-shell" class="space-y-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          {{if eq .AuthMode "api_key"}}
          <p class="text-sm text-muted-foreground">
            Active key: <span id="active-api-key" class="font-mono text-primary">Not set</span>
          </p>
          <button id="clear-api-key" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
            Clear key
          </button>
          {{else}}
          <div>
            <h1 class="text-3xl font-display font-bold">Extract</h1>
            <p class="text-muted-foreground mt-1">Extract structured data from documents using AI.</p>
          </div>
          {{end}}
        </div>

        <!-- Sub-tab navigation -->
        <div class="border-b border-border">
          <nav class="flex gap-0 -mb-px" id="extract-tabs">
            <button type="button" class="extract-tab active px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-foreground" data-tab="process">
              Process Documents
            </button>
            <button type="button" class="extract-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground hover:border-border transition-colors" data-tab="templates">
              Manage Templates
            </button>
            <button type="button" class="extract-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground hover:border-border transition-colors" data-tab="settings">
              Settings
            </button>
            <button type="button" class="extract-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-muted-foreground hover:text-foreground hover:border-border transition-colors" data-tab="api">
              API Integration
            </button>
          </nav>
        </div>

        <!-- Tab: Process Documents -->
        <div id="extract-tab-process" class="extract-tab-content space-y-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Left: Upload form -->
            <div class="space-y-4">
              <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-4">
                <h3 class="text-lg font-display font-semibold">Upload Document</h3>

                <div class="space-y-2">
                  <label for="extract-template-select" class="text-sm font-medium leading-none">Template</label>
                  <select id="extract-template-select" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2">
                    <option value="">Loading templates...</option>
                  </select>
                </div>

                <div class="space-y-2">
                  <label class="text-sm font-medium leading-none">File</label>
                  <div id="extract-dropzone" class="relative rounded-lg border-2 border-dashed border-input bg-muted/30 p-8 text-center cursor-pointer hover:border-primary/50 hover:bg-muted/50 transition-colors">
                    <input type="file" id="extract-file-input" accept=".jpg,.jpeg,.png,.pdf" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
                    <div class="space-y-2">
                      <svg class="mx-auto h-10 w-10 text-muted-foreground/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                      </svg>
                      <p class="text-sm text-muted-foreground">
                        <span class="font-medium text-primary">Click to upload</span> or drag and drop
                      </p>
                      <p class="text-xs text-muted-foreground">JPG, PNG, or PDF (max 10MB)</p>
                    </div>
                  </div>
                  <p id="extract-file-name" class="text-sm text-muted-foreground hidden"></p>
                </div>

                <button id="extract-process-btn" type="button" disabled class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                  <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  Process Document
                </button>
              </div>
            </div>

            <!-- Right: Results -->
            <div class="space-y-4">
              <div id="extract-results-panel" class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 min-h-[200px]">
                <h3 class="text-lg font-display font-semibold mb-4">Extraction Results</h3>
                <div id="extract-results-content">
                  <p class="text-sm text-muted-foreground">Upload a document and click "Process Document" to see results.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Jobs -->
          <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
            <div class="p-6 pb-2">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-display font-semibold">Recent Jobs</h3>
                <button id="extract-refresh-jobs" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-8 px-3 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
                  Refresh
                </button>
              </div>
            </div>
            <div class="px-6 pb-6">
              <div id="extract-jobs-table" class="mt-2">
                <div class="flex items-center gap-2 text-sm text-muted-foreground py-4">
                  <div class="spinner border-current"></div>
                  Loading jobs...
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab: Manage Templates -->
        <div id="extract-tab-templates" class="extract-tab-content hidden space-y-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-lg font-display font-semibold">Extract Templates</h3>
              <p class="text-sm text-muted-foreground mt-1">Configure document extraction templates.</p>
            </div>
            <div class="flex gap-2">
              <button id="extract-reset-defaults-btn" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
                Reset Defaults
              </button>
              <button id="extract-new-template-btn" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
                New Template
              </button>
            </div>
          </div>

          <!-- Template form (hidden by default) -->
          <div id="extract-template-form-wrapper" class="hidden">
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-4">
              <div class="flex items-center justify-between">
                <h3 id="extract-template-form-title" class="text-lg font-display font-semibold">New Template</h3>
                <button id="extract-template-form-cancel" type="button" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Cancel</button>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-2">
                  <label for="tpl-id" class="text-sm font-medium leading-none">Template ID</label>
                  <input id="tpl-id" type="text" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" placeholder="my_template">
                </div>
                <div class="space-y-2">
                  <label for="tpl-name" class="text-sm font-medium leading-none">Name</label>
                  <input id="tpl-name" type="text" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" placeholder="My Template">
                </div>
              </div>
              <div class="space-y-2">
                <label for="tpl-description" class="text-sm font-medium leading-none">Description</label>
                <input id="tpl-description" type="text" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" placeholder="Description of what this template extracts">
              </div>
              <div class="space-y-2">
                <label for="tpl-model" class="text-sm font-medium leading-none">Model Override</label>
                <select id="tpl-model" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                  <option value="">Use default model</option>
                </select>
              </div>
              <div class="space-y-2">
                <label for="tpl-system-prompt" class="text-sm font-medium leading-none">System Prompt</label>
                <textarea id="tpl-system-prompt" rows="4" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring resize-y min-h-[100px]" placeholder="You are a document extraction assistant..."></textarea>
              </div>
              <div class="space-y-2">
                <label for="tpl-user-prompt" class="text-sm font-medium leading-none">User Prompt</label>
                <textarea id="tpl-user-prompt" rows="4" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring resize-y min-h-[100px]" placeholder="Extract the following fields from this document..."></textarea>
              </div>
              <button id="extract-template-form-save" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-6 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
                Save Template
              </button>
            </div>
          </div>

          <!-- Template cards grid -->
          <div id="extract-templates-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="flex items-center gap-2 text-sm text-muted-foreground py-4">
              <div class="spinner border-current"></div>
              Loading templates...
            </div>
          </div>
        </div>

        <!-- Tab: Settings -->
        <div id="extract-tab-settings" class="extract-tab-content hidden space-y-6">
          <div class="max-w-xl space-y-6">
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-4">
              <h3 class="text-lg font-display font-semibold">Extract Settings</h3>
              <p class="text-sm text-muted-foreground">Configure the default vision model and file size limits.</p>

              <div class="space-y-2">
                <label for="extract-default-model" class="text-sm font-medium leading-none">Default Vision Model</label>
                <select id="extract-default-model" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                  <option value="">Loading models...</option>
                </select>
                <p class="text-xs text-muted-foreground">
                  Model selection priority: Template override &rarr; Default model (this setting) &rarr; Auto-detect from provider.
                </p>
              </div>

              <button id="extract-save-settings-btn" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-6 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
                Save Settings
              </button>
            </div>
          </div>
        </div>

        <!-- Tab: API Integration -->
        <div id="extract-tab-api" class="extract-tab-content hidden space-y-6">
          <div class="max-w-3xl space-y-6">
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-4">
              <h3 class="text-lg font-display font-semibold">API Integration</h3>
              <p class="text-sm text-muted-foreground">Use the Extract API to process documents programmatically.</p>

              <div class="space-y-2">
                <label class="text-sm font-medium leading-none">Base URL</label>
                <div class="flex items-center gap-2">
                  <code id="extract-api-base-url" class="flex-1 block rounded-md border bg-muted px-3 py-2 text-sm font-mono break-all"></code>
                  <button id="extract-copy-base-url" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors shrink-0">
                    Copy
                  </button>
                </div>
              </div>

              <div class="space-y-2">
                <label class="text-sm font-medium leading-none">Authentication</label>
                <p class="text-sm text-muted-foreground">All requests require a Bearer token. Include an <code class="text-xs bg-muted px-1 py-0.5 rounded font-mono">Authorization: Bearer &lt;api_key&gt;</code> header with an API key that has the <code class="text-xs bg-muted px-1 py-0.5 rounded font-mono">extract</code> scope.</p>
              </div>
            </div>

            <!-- curl example -->
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-3">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-semibold">curl</h4>
                <button class="extract-copy-code inline-flex items-center justify-center rounded-md text-xs font-medium h-7 px-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors" data-target="code-curl">Copy</button>
              </div>
              <pre id="code-curl" class="rounded-md bg-muted p-4 text-xs font-mono overflow-x-auto whitespace-pre text-foreground"><code>curl -X POST <span class="extract-api-url-placeholder"></span>/process \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -F "template_id=general_document" \
  -F "file=@document.pdf"</code></pre>
            </div>

            <!-- Python example -->
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-3">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-semibold">Python</h4>
                <button class="extract-copy-code inline-flex items-center justify-center rounded-md text-xs font-medium h-7 px-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors" data-target="code-python">Copy</button>
              </div>
              <pre id="code-python" class="rounded-md bg-muted p-4 text-xs font-mono overflow-x-auto whitespace-pre text-foreground"><code>import requests

url = "<span class="extract-api-url-placeholder"></span>/process"
headers = {"Authorization": "Bearer YOUR_API_KEY"}
files = {"file": open("document.pdf", "rb")}
data = {"template_id": "general_document"}

response = requests.post(url, headers=headers, files=files, data=data)
result = response.json()
print(result["data"])</code></pre>
            </div>

            <!-- JavaScript example -->
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 space-y-3">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-semibold">JavaScript</h4>
                <button class="extract-copy-code inline-flex items-center justify-center rounded-md text-xs font-medium h-7 px-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors" data-target="code-js">Copy</button>
              </div>
              <pre id="code-js" class="rounded-md bg-muted p-4 text-xs font-mono overflow-x-auto whitespace-pre text-foreground"><code>const form = new FormData();
form.append("template_id", "general_document");
form.append("file", fileInput.files[0]);

const response = await fetch("<span class="extract-api-url-placeholder"></span>/process", {
  method: "POST",
  headers: { "Authorization": "Bearer YOUR_API_KEY" },
  body: form,
});

const result = await response.json();
console.log(result.data);</code></pre>
            </div>
          </div>
        </div>

      </section>
    </div>
  </main>

{{template "layout-toast" .}}
{{end}}
