{{define "partial-usage"}}
<div class="space-y-6">
  <!-- Stat cards row -->
  <div class="grid gap-4 sm:grid-cols-3">
    <!-- Total Requests -->
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Total Requests</p>
          <p class="text-2xl font-bold mt-1">{{.TotalRequests}}</p>
        </div>
        <div class="p-3 rounded-full bg-blue-500/10 text-blue-500">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
      </div>
    </div>
    <!-- Total Tokens -->
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Total Tokens</p>
          <p class="text-2xl font-bold mt-1">{{.TotalTokens}}</p>
        </div>
        <div class="p-3 rounded-full bg-purple-500/10 text-purple-500">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
          </svg>
        </div>
      </div>
    </div>
    <!-- Total Cost -->
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-5">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-muted-foreground">Total Cost</p>
          <p class="text-2xl font-bold mt-1">{{.TotalCostDisplay}}</p>
        </div>
        <div class="p-3 rounded-full bg-green-500/10 text-green-500">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Two-column grid: Endpoint + Model breakdowns -->
  <div class="grid gap-4 md:grid-cols-2">
    <!-- Usage by Endpoint -->
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
      <div class="p-5 pb-3 border-b">
        <h4 class="text-sm font-semibold">Usage by Endpoint</h4>
      </div>
      <div class="p-5 pt-3">
        {{if .ByEndpoint}}
        <div class="space-y-3">
          {{range .ByEndpoint}}
          <div class="flex items-center justify-between text-sm">
            <span class="font-mono text-xs truncate mr-3">{{.Endpoint}}</span>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-muted-foreground">{{.RequestCount}} req</span>
              <span class="text-muted-foreground">&middot;</span>
              <span class="text-muted-foreground">{{.TotalTokens}} tok</span>
            </div>
          </div>
          {{end}}
        </div>
        {{else}}
        <p class="text-sm text-muted-foreground text-center py-4">No endpoint data available.</p>
        {{end}}
      </div>
    </div>
    <!-- Usage by Model -->
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
      <div class="p-5 pb-3 border-b">
        <h4 class="text-sm font-semibold">Usage by Model</h4>
      </div>
      <div class="p-5 pt-3">
        {{if .ByModel}}
        <div class="space-y-3">
          {{range .ByModel}}
          <div class="flex items-center justify-between text-sm">
            <span class="font-mono text-xs truncate mr-3">{{.Model}}</span>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-muted-foreground">{{.RequestCount}} req</span>
              <span class="text-muted-foreground">&middot;</span>
              <span class="text-muted-foreground">{{.TotalTokens}} tok</span>
            </div>
          </div>
          {{end}}
        </div>
        {{else}}
        <p class="text-sm text-muted-foreground text-center py-4">No model data available.</p>
        {{end}}
      </div>
    </div>
  </div>

  <!-- Per-key breakdown table -->
  <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
    <div class="p-5 pb-3 border-b">
      <h4 class="text-sm font-semibold">Usage by API Key</h4>
    </div>
    <div class="rounded-md overflow-hidden">
      <table class="w-full caption-bottom text-sm">
        <thead class="[&_tr]:border-b bg-muted/50">
          <tr class="border-b transition-colors">
            <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground text-xs">API Key</th>
            <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground text-xs">Requests</th>
            <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground text-xs">Tokens</th>
            <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground text-xs">Cost</th>
          </tr>
        </thead>
        <tbody class="[&_tr:last-child]:border-0">
          {{range .Rows}}
          <tr class="border-b transition-colors hover:bg-muted/50">
            <td class="p-4 align-middle">#{{.APIKeyID}} {{.APIKeyName}}</td>
            <td class="p-4 align-middle">{{.RequestCount}}</td>
            <td class="p-4 align-middle">{{.TotalTokens}}</td>
            <td class="p-4 align-middle">{{.CostDisplay}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="p-8 text-center text-muted-foreground">No usage activity in this window.</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  </div>
</div>
{{end}}
