{{define "page-analytics"}}
{{template "layout-head" .}}
{{template "layout-nav" .}}

  <main class="pt-16 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 space-y-6">
      <div id="dashboard-message" class="min-h-[1.5rem] text-sm"></div>

      {{if eq .AuthMode "api_key"}}
      <section id="api-key-login-panel" class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
        <h2 class="text-lg font-display font-semibold">Unlock dashboard</h2>
        <p class="mt-1 text-sm text-muted-foreground">
          Paste an API key with dashboard scopes to authenticate browser actions.
        </p>
        <form id="api-key-form" class="mt-4 flex flex-col gap-3 sm:flex-row" autocomplete="off">
          <input id="api-key-input" type="password" required class="flex h-10 min-w-0 flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" placeholder="enc_...">
          <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4">
            Use this key
          </button>
        </form>
        <p class="mt-2 text-xs text-muted-foreground">The key is stored in this browser only (localStorage).</p>
      </section>
      {{end}}

      <section id="dashboard-shell" class="space-y-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          {{if eq .AuthMode "api_key"}}
          <p class="text-sm text-muted-foreground">
            Active key: <span id="active-api-key" class="font-mono text-primary">Not set</span>
          </p>
          <button id="clear-api-key" type="button" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-3 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
            Clear key
          </button>
          {{else}}
          <div>
            <h1 class="text-3xl font-display font-bold">Analytics</h1>
            <p class="text-muted-foreground mt-1">Usage statistics and insights</p>
          </div>
          {{end}}
        </div>

        <!-- Time range selector -->
        <div class="flex items-center gap-2" id="analytics-time-range">
          <button type="button"
                  class="analytics-range-btn inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                  hx-get="/dashboard/partials/usage?days=7"
                  hx-target="#dashboard-usage"
                  hx-swap="innerHTML"
                  data-days="7"
                  onclick="setActiveRange(this)">
            7 Days
          </button>
          <button type="button"
                  class="analytics-range-btn inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
                  hx-get="/dashboard/partials/usage?days=30"
                  hx-target="#dashboard-usage"
                  hx-swap="innerHTML"
                  data-days="30"
                  onclick="setActiveRange(this)">
            30 Days
          </button>
          <button type="button"
                  class="analytics-range-btn inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                  hx-get="/dashboard/partials/usage?days=90"
                  hx-target="#dashboard-usage"
                  hx-swap="innerHTML"
                  data-days="90"
                  onclick="setActiveRange(this)">
            90 Days
          </button>
        </div>

        <script>
        function setActiveRange(el) {
          var btns = document.querySelectorAll('.analytics-range-btn');
          btns.forEach(function(btn) {
            btn.className = 'analytics-range-btn inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors';
          });
          el.className = 'analytics-range-btn inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors';
        }
        </script>

        <section>
          <div id="dashboard-usage" hx-get="/dashboard/partials/usage?days=30" hx-trigger="load" hx-target="this" hx-swap="innerHTML">
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
              <div class="spinner border-current"></div>
              Loading analytics...
            </div>
          </div>
        </section>
      </section>
    </div>
  </main>

{{template "layout-toast" .}}
{{end}}
