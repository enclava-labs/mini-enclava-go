{{define "partial-extract"}}
<div class="space-y-6">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <p class="text-sm font-medium text-muted-foreground">Jobs (24h)</p>
      <p class="text-2xl font-bold mt-1">{{.RecentJobs}}</p>
    </div>
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <p class="text-sm font-medium text-muted-foreground">Total Jobs</p>
      <p class="text-2xl font-bold mt-1">{{.TotalJobs}}</p>
    </div>
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
      <p class="text-sm font-medium text-muted-foreground">Templates</p>
      <p class="text-2xl font-bold mt-1">{{len .Templates}}</p>
    </div>
  </div>

  <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
    <div class="p-6">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-display font-semibold">Extract Templates</h3>
          <p class="text-sm text-muted-foreground mt-1">Available document extraction templates.</p>
        </div>
        <a href="/api/v1/extract/health" class="inline-flex items-center justify-center rounded-md text-sm font-medium h-9 px-4 border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors">
          Health
        </a>
      </div>
    </div>

    {{if not .Templates}}
    <div class="px-6 pb-6">
      <p class="text-sm text-muted-foreground">No templates configured.</p>
    </div>
    {{else}}
    <div class="px-6 pb-6">
      <div class="rounded-md border overflow-hidden">
        <table class="w-full caption-bottom text-sm">
          <thead class="[&_tr]:border-b bg-muted/50">
            <tr class="border-b transition-colors">
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">ID</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Name</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Description</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Model</th>
              <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Status</th>
            </tr>
          </thead>
          <tbody class="[&_tr:last-child]:border-0">
            {{range .Templates}}
            <tr class="border-b transition-colors hover:bg-muted/50">
              <td class="p-4 align-middle font-mono text-sm">{{.ID}}</td>
              <td class="p-4 align-middle font-medium">{{.Name}}</td>
              <td class="p-4 align-middle text-muted-foreground">{{if .Description}}{{.Description}}{{else}}—{{end}}</td>
              <td class="p-4 align-middle font-mono text-sm">{{if .Model}}{{.Model}}{{else}}default{{end}}</td>
              <td class="p-4 align-middle">
                {{if .IsActive}}
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-200">Active</span>
                {{else}}
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-gray-100 dark:bg-gray-900/20 text-gray-800 dark:text-gray-200">Inactive</span>
                {{end}}
              </td>
            </tr>
            {{end}}
          </tbody>
        </table>
      </div>
    </div>
    {{end}}
  </div>
</div>
{{end}}
