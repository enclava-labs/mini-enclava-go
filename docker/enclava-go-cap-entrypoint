#!/bin/sh
set -eu

CONFIG_DIR="${ENCLAVA_CONFIG_DIR:-/state/app-data/.enclava/config}"
REQUIRED_KEYS="${ENCLAVA_REQUIRED_CONFIG_KEYS:-}"
APP_BIN="${ENCLAVA_APP_BIN:-/usr/local/bin/app}"
APP_RESTART_LIMIT="${ENCLAVA_APP_RESTART_LIMIT:-0}"
APP_RESTART_DELAY_SECONDS="${ENCLAVA_APP_RESTART_DELAY_SECONDS:-5}"
APP_RESTART_MAX_DELAY_SECONDS="${ENCLAVA_APP_RESTART_MAX_DELAY_SECONDS:-30}"

is_uint() {
	case "$1" in
		''|*[!0-9]*)
			return 1
			;;
		*)
			return 0
			;;
	esac
}

load_config_dir() {
	if [ ! -d "$CONFIG_DIR" ]; then
		return 0
	fi

	for path in "$CONFIG_DIR"/*; do
		[ -f "$path" ] || continue
		key="$(basename "$path")"
		case "$key" in
			''|*[!A-Za-z0-9_]*)
				echo "ignoring invalid config key file: $key" >&2
				continue
				;;
		esac
		value="$(cat "$path")"
		export "$key=$value"
	done
}

wait_for_required_keys() {
	[ -n "$REQUIRED_KEYS" ] || return 0

	for key in $(printf '%s' "$REQUIRED_KEYS" | tr ',' ' '); do
		[ -n "$key" ] || continue
		path="$CONFIG_DIR/$key"
		while [ ! -s "$path" ]; do
			echo "waiting for encrypted config key: $key" >&2
			sleep 2
		done
	done
}

wait_for_required_keys

export APP_HOST="${APP_HOST:-0.0.0.0}"
export APP_PORT="${APP_PORT:-8080}"
export DATABASE_URL="${DATABASE_URL:-/state/app-data/enclava.db}"
export TRUST_PROXY_HEADERS="${TRUST_PROXY_HEADERS:-true}"

db_dir="$(dirname "$DATABASE_URL")"
if [ -n "$db_dir" ] && [ "$db_dir" != "." ]; then
	mkdir -p "$db_dir" 2>/dev/null || true
fi

if ! is_uint "$APP_RESTART_LIMIT"; then
	echo "ENCLAVA_APP_RESTART_LIMIT must be a non-negative integer" >&2
	exit 2
fi
if ! is_uint "$APP_RESTART_DELAY_SECONDS"; then
	echo "ENCLAVA_APP_RESTART_DELAY_SECONDS must be a non-negative integer" >&2
	exit 2
fi
if ! is_uint "$APP_RESTART_MAX_DELAY_SECONDS"; then
	echo "ENCLAVA_APP_RESTART_MAX_DELAY_SECONDS must be a non-negative integer" >&2
	exit 2
fi

restarts=0
delay="$APP_RESTART_DELAY_SECONDS"
child_pid=""

forward_term() {
	if [ -n "$child_pid" ]; then
		kill -TERM "$child_pid" 2>/dev/null || true
		wait "$child_pid" 2>/dev/null || true
	fi
	exit 143
}

trap forward_term INT TERM

while :; do
	load_config_dir
	"$APP_BIN" &
	child_pid="$!"
	set +e
	wait "$child_pid"
	status="$?"
	set -e
	if [ "$status" -eq 0 ]; then
		exit 0
	fi
	child_pid=""

	if [ "$APP_RESTART_LIMIT" -gt 0 ] && [ "$restarts" -ge "$APP_RESTART_LIMIT" ]; then
		echo "app exited with status $status after $restarts restart(s); exiting" >&2
		exit "$status"
	fi

	restarts=$((restarts + 1))
	echo "app exited with status $status; restarting inside CAP container (restart $restarts)" >&2
	sleep "$delay"
	if [ "$APP_RESTART_MAX_DELAY_SECONDS" -gt 0 ] && [ "$delay" -lt "$APP_RESTART_MAX_DELAY_SECONDS" ]; then
		delay=$((delay * 2))
		if [ "$delay" -gt "$APP_RESTART_MAX_DELAY_SECONDS" ]; then
			delay="$APP_RESTART_MAX_DELAY_SECONDS"
		fi
	fi
done
