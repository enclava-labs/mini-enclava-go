APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=./enclava.db
MAX_UPLOAD_SIZE_MB=15

# HTTP server timeouts
HTTP_READ_TIMEOUT=30s
# For SSE streaming, keep this at 0 (disabled) unless you know you don't need streaming.
HTTP_WRITE_TIMEOUT=0
HTTP_IDLE_TIMEOUT=60s
HTTP_READ_HEADER_TIMEOUT=10s

# Provider selection: privatemode | tinfoil
INFERENCE_PROVIDER=privatemode

PRIVATEMODE_BASE_URL=https://api.privatemode.ai/v1
PRIVATEMODE_API_KEY=sk-...
PRIVATEMODE_TIMEOUT=120s

# Provider readiness probing (controls /readyz and startup availability)
PROVIDER_PROBE_INTERVAL=5s
PROVIDER_PROBE_TIMEOUT=10s

# API key hashing for keys stored in sqlite
# sha256 = legacy compatibility
# hmac_sha256 = preferred (requires API_KEY_PEPPER)
API_KEY_HASH_ALGO=sha256
API_KEY_PEPPER=
API_KEY_PREFIX=enc_
TRUST_PROXY_HEADERS=false

# Optional dashboard login (if set, /dashboard uses email/password session auth)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Tinfoil provider settings (used when INFERENCE_PROVIDER=tinfoil)
TINFOIL_API_KEY=
TINFOIL_ENCLAVE=
TINFOIL_REPO=
TINFOIL_VERIFY_AT_START=true
TINFOIL_VERIFY_PER_CALL=false
TINFOIL_VERIFY_MAX_AGE=10m

# Optional: operator bootstrap key for first startup only.
# Must be explicitly enabled and strong (no placeholder/example keys).
BOOTSTRAP_ENABLED=false
# BOOTSTRAP_API_KEY=
BOOTSTRAP_API_KEY=
BOOTSTRAP_API_KEY_MIN_LENGTH=48
